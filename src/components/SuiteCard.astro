---
import type { Suite } from '../types/client';
import { formatDateOnly } from '../utils/format';

interface Props {
  suite: Suite;
}

const { suite } = Astro.props;

const isPassing = suite.failed === 0;
const metaDate = formatDateOnly(suite.lastRun);

// Last 6 runs for sparkline; fall back to current run if no history
const history = suite.history ?? [{ passed: suite.passed, total: suite.total }];
const sparkBars = history.slice(-6);

// Build aria description for sparkline
const sparkDesc = sparkBars
  .map((r) => (r.passed === r.total ? 'passing' : 'failing'))
  .join(', ');
---

<article class="suite-card">
  <div class="suite-left">
    <span
      class:list={['status-dot', isPassing ? 'status-dot-pass' : 'status-dot-fail']}
      role="img"
      aria-label={isPassing ? 'Suite passing' : 'Suite failing'}
    ></span>
    <div class="suite-info">
      <h2 class="suite-name">{suite.name}</h2>
      <p class="suite-meta">
        <span class="meta-pass">{suite.passed} passed</span>
        {suite.failed > 0 && (
          <span class="meta-muted">, <span class="meta-fail">{suite.failed} failed</span></span>
        )}
        <span class="meta-muted"> of {suite.total} total · Last run {metaDate}</span>
      </p>
      <div
        class="sparkline"
        role="img"
        aria-label={`Run history (last ${sparkBars.length}): ${sparkDesc}`}
      >
        {sparkBars.map((run) => {
          const rate = run.total > 0 ? run.passed / run.total : 0;
          const barPassing = run.passed === run.total;
          const heightPx = Math.max(3, Math.round(rate * 20));
          return (
            <div
              class:list={['spark-bar', barPassing ? 'spark-bar-pass' : 'spark-bar-fail']}
              style={`height: ${heightPx}px`}
            ></div>
          );
        })}
      </div>
    </div>
  </div>
  <div class="suite-right">
    <a
      href={suite.reportUrl}
      class="view-report-btn"
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`View report for ${suite.name}`}
    >
      View Report
    </a>
  </div>
</article>

<style>
  .suite-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 18px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 10px;
    transition: border-color 200ms ease-out;
  }

  .suite-card:hover {
    border-color: var(--border-hover);
  }

  .suite-left {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    flex: 1;
    min-width: 0;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 5px;
  }

  .status-dot-pass { background: var(--pass); }
  .status-dot-fail { background: var(--fail); }

  .suite-info {
    flex: 1;
    min-width: 0;
  }

  .suite-name {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: var(--fg-primary);
    margin-bottom: 3px;
  }

  .suite-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--fg-muted);
  }

  .meta-pass { color: var(--pass); }
  .meta-fail { color: var(--fail); }
  .meta-muted { color: var(--fg-muted); }

  /* ── Sparkline ── */
  .sparkline {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 20px;
    margin-top: 6px;
  }

  .spark-bar {
    width: 5px;
    border-radius: 2px;
    min-height: 3px;
  }

  .spark-bar-pass { background: var(--pass); }
  .spark-bar-fail { background: var(--fail); }

  /* ── View Report button ── */
  .suite-right {
    flex-shrink: 0;
  }

  .view-report-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    color: var(--bg-base);
    border: none;
    border-radius: 8px;
    height: 36px;
    padding: 0 16px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: filter 200ms ease-out;
    white-space: nowrap;
  }

  .view-report-btn:hover {
    filter: brightness(1.1);
  }

  .view-report-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
