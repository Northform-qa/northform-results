---
import { readdir, readFile } from 'node:fs/promises';
import path from 'node:path';
import type { ClientConfig } from '../../types/client';
import { formatDateOnly, formatTimeOnly } from '../../utils/format';
import SuiteCard from '../../components/SuiteCard.astro';

export async function getStaticPaths() {
  const clientsDir = path.resolve('./clients');
  const slugs = await readdir(clientsDir);
  return Promise.all(
    slugs.map(async (slug) => {
      const raw = await readFile(path.join(clientsDir, slug, 'config.json'), 'utf-8');
      const config = JSON.parse(raw) as ClientConfig;
      return { params: { slug }, props: { config } };
    })
  );
}

const { config } = Astro.props as { config: ClientConfig };

const lastRun = config.suites.reduce(
  (latest, suite) => (suite.lastRun > latest ? suite.lastRun : latest),
  config.suites[0]?.lastRun ?? ''
);

const totalPassed = config.suites.reduce((sum, s) => sum + s.passed, 0);
const totalFailed = config.suites.reduce((sum, s) => sum + s.failed, 0);
const totalTests  = config.suites.reduce((sum, s) => sum + s.total, 0);
const allPassing  = totalFailed === 0 && totalTests > 0;

const lastRunDate = lastRun ? formatDateOnly(lastRun) : 'No data';
const lastRunTime = lastRun ? formatTimeOnly(lastRun) : '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{config.displayName} — Test Results | Northform QA</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg-base:       #0A0A0F;
        --bg-elevated:   #12121A;
        --bg-surface:    #1A1A24;
        --bg-card:       rgba(26, 26, 36, 0.6);
        --fg-primary:    #FAFAFA;
        --fg-muted:      #A1A1AA;
        --accent:        #F59E0B;
        --accent-muted:  rgba(245, 158, 11, 0.1);
        --accent-border: rgba(245, 158, 11, 0.25);
        --pass:          #1ECFA0;
        --pass-muted:    rgba(30, 207, 160, 0.1);
        --pass-border:   rgba(30, 207, 160, 0.2);
        --fail:          #E24B4A;
        --border:        rgba(255, 255, 255, 0.08);
        --border-hover:  rgba(255, 255, 255, 0.15);
      }

      html {
        scroll-padding-top: 68px; /* prevent sticky nav from obscuring focused elements */
      }

      body {
        background: var(--bg-base);
        color: var(--fg-primary);
        font-family: 'Inter', system-ui, sans-serif;
        min-height: 100vh;
      }

      /* ── Nav ── */
      nav {
        height: 52px;
        background: var(--bg-elevated);
        border-bottom: 1px solid var(--border);
        padding: 0 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .nav-brand {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
        text-decoration: none;
      }

      .nav-brand:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
        border-radius: 4px;
      }

      .nav-slug {
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        color: var(--fg-muted);
      }

      /* ── Main ── */
      main {
        max-width: 860px;
        margin: 0 auto;
        padding: 40px 24px;
      }

      /* ── Header ── */
      .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 28px;
      }

      .header-client-name {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: 22px;
        font-weight: 600;
        color: var(--fg-primary);
        margin-bottom: 4px;
      }

      .header-last-run {
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        color: var(--fg-muted);
      }

      /* ── Status badges ── */
      .badge {
        display: inline-flex;
        align-items: center;
        border-radius: 9999px;
        padding: 5px 12px;
        font-size: 12px;
        font-weight: 500;
        font-family: 'Inter', system-ui, sans-serif;
        white-space: nowrap;
        flex-shrink: 0;
      }

      .badge-pass {
        background: var(--pass-muted);
        border: 1px solid var(--pass-border);
        color: var(--pass);
      }

      .badge-fail {
        background: rgba(226, 75, 74, 0.1);
        border: 1px solid rgba(226, 75, 74, 0.2);
        color: var(--fail);
      }

      .badge-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--pass);
        display: inline-block;
        margin-right: 6px;
        flex-shrink: 0;
      }

      /* ── Stats row ── */
      .stats-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: rgba(255, 255, 255, 0.06);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 28px;
      }

      .stat-cell {
        background: var(--bg-elevated);
        padding: 20px 24px;
      }

      .stat-number {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: 32px;
        font-weight: 600;
        line-height: 1;
      }

      .stat-number-total { color: var(--fg-primary); }
      .stat-number-pass  { color: var(--pass); }
      .stat-number-fail  { color: var(--fail); }

      .stat-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--fg-muted);
        margin-top: 6px;
      }

      /* ── Section label ── */
      .section-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--fg-muted);
        margin-bottom: 12px;
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="/" class="nav-brand">Northform QA</a>
      <span class="nav-slug">{config.slug}</span>
    </nav>

    <main>
      <!-- Header row -->
      <div class="page-header">
        <div>
          <h1 class="header-client-name">{config.displayName}</h1>
          <p class="header-last-run">
            {lastRun
              ? `Last run: ${lastRunDate} · ${lastRunTime} ET`
              : 'No data'}
          </p>
        </div>
        <div>
          {allPassing ? (
            <span class="badge badge-pass" role="status" aria-label="All tests passing">
              <span class="badge-dot" aria-hidden="true"></span>
              All passing
            </span>
          ) : (
            <span class="badge badge-fail" role="status" aria-label={`${totalFailed} test${totalFailed !== 1 ? 's' : ''} failing`}>
              {totalFailed} failing
            </span>
          )}
        </div>
      </div>

      <!-- Stats row -->
      <div class="stats-row" role="region" aria-label="Test summary statistics">
        <div class="stat-cell">
          <div class="stat-number stat-number-total">{totalTests}</div>
          <div class="stat-label">Total</div>
        </div>
        <div class="stat-cell">
          <div class="stat-number stat-number-pass">{totalPassed}</div>
          <div class="stat-label">Passed</div>
        </div>
        <div class="stat-cell">
          <div class="stat-number stat-number-fail">{totalFailed}</div>
          <div class="stat-label">Failed</div>
        </div>
      </div>

      <!-- Section label -->
      <p class="section-label" aria-hidden="true">Test Suites</p>

      <!-- Suite cards -->
      <section aria-label="Test suites">
        {config.suites.map((suite) => (
          <SuiteCard suite={suite} />
        ))}
      </section>
    </main>
  </body>
</html>
