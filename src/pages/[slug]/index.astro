---
import { readdir, readFile } from 'node:fs/promises';
import path from 'node:path';
import type { ClientConfig } from '../../types/client';
import { formatDate } from '../../utils/format';
import SuiteCard from '../../components/SuiteCard.astro';

export async function getStaticPaths() {
  const clientsDir = path.resolve('./clients');
  const slugs = await readdir(clientsDir);
  return Promise.all(
    slugs.map(async (slug) => {
      const raw = await readFile(path.join(clientsDir, slug, 'config.json'), 'utf-8');
      const config = JSON.parse(raw) as ClientConfig;
      return { params: { slug }, props: { config } };
    })
  );
}

const { config } = Astro.props as { config: ClientConfig };

const lastRun = config.suites.reduce(
  (latest, suite) => (suite.lastRun > latest ? suite.lastRun : latest),
  config.suites[0]?.lastRun ?? ''
);

const totalPassed = config.suites.reduce((sum, s) => sum + s.passed, 0);
const totalFailed = config.suites.reduce((sum, s) => sum + s.failed, 0);
const totalTests  = config.suites.reduce((sum, s) => sum + s.total, 0);
const allPassing  = totalFailed === 0 && totalTests > 0;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{config.displayName} — Test Results</title>
    <style define:vars={{ brandColour: config.brandColour }}>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: system-ui, sans-serif; background: #f5f5f5; color: #111; }

      .accent-bar { height: 4px; background: var(--brandColour); }

      header {
        background: #0a0a0a;
        color: #fff;
        padding: 1.25rem 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
      }
      header img { height: 32px; width: auto; }
      header h1 { font-size: 1.15rem; font-weight: 600; }
      .powered { margin-left: auto; font-size: 0.75rem; color: #777; }
      .powered a { color: #999; text-decoration: none; }
      .powered a:hover { color: #ccc; }

      main { max-width: 900px; margin: 2rem auto; padding: 0 1.5rem; }

      .meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
      }
      .last-run { font-size: 0.85rem; color: #666; }

      .status-badge {
        font-size: 0.78rem;
        font-weight: 700;
        padding: 0.3rem 0.85rem;
        border-radius: 999px;
        background: #27ae60;
        color: #fff;
        letter-spacing: 0.02em;
      }
      .status-badge.fail { background: #c0392b; }

      .summary {
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 1.25rem 1.75rem;
        margin-bottom: 2rem;
        display: flex;
        gap: 2.5rem;
      }
      .stat .num {
        font-size: 2.25rem;
        font-weight: 700;
        line-height: 1;
        color: #111;
      }
      .stat .num.pass { color: #27ae60; }
      .stat .num.fail { color: #c0392b; }
      .stat .label {
        font-size: 0.73rem;
        font-weight: 600;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-top: 0.3rem;
      }

      h2 {
        font-size: 0.78rem;
        font-weight: 600;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 0.75rem;
      }
      .suites { display: flex; flex-direction: column; gap: 0.75rem; }
    </style>
  </head>
  <body>
    <div class="accent-bar"></div>
    <header>
      {config.logoUrl && (
        <img src={config.logoUrl} alt={`${config.displayName} logo`} />
      )}
      <h1>{config.displayName}</h1>
      <span class="powered">
        powered by <a href="https://northformqa.ca">Northform QA</a>
      </span>
    </header>

    <main>
      <div class="meta">
        <p class="last-run">
          Last run: {lastRun ? formatDate(lastRun) : 'No data'}
        </p>
        <span class={`status-badge${allPassing ? '' : ' fail'}`}>
          {allPassing ? 'All passing' : `${totalFailed} failing`}
        </span>
      </div>

      <div class="summary">
        <div class="stat">
          <div class="num">{totalTests}</div>
          <div class="label">Total</div>
        </div>
        <div class="stat">
          <div class="num pass">{totalPassed}</div>
          <div class="label">Passed</div>
        </div>
        <div class="stat">
          <div class="num fail">{totalFailed}</div>
          <div class="label">Failed</div>
        </div>
      </div>

      <h2>Test Suites</h2>
      <div class="suites">
        {config.suites.map((suite) => (
          <SuiteCard suite={suite} brandColour={config.brandColour} />
        ))}
      </div>
    </main>
  </body>
</html>
