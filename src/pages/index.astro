---
import { readdir, readFile } from 'node:fs/promises';
import path from 'node:path';
import type { ClientConfig } from '../types/client';

const clientsDir = path.resolve('./clients');
const slugs = await readdir(clientsDir);
const clients: ClientConfig[] = await Promise.all(
  slugs.map(async (slug) => {
    const raw = await readFile(path.join(clientsDir, slug, 'config.json'), 'utf-8');
    return JSON.parse(raw) as ClientConfig;
  })
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Northform QA — Results</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: system-ui, sans-serif; background: #f5f5f5; color: #111; }
      header {
        background: #0a0a0a;
        color: #fff;
        padding: 1.25rem 2rem;
      }
      header h1 { font-size: 1.1rem; font-weight: 600; }
      header p { font-size: 0.8rem; color: #888; margin-top: 0.25rem; }
      main { max-width: 680px; margin: 2.5rem auto; padding: 0 1.5rem; }
      h2 {
        font-size: 0.8rem;
        font-weight: 600;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 0.75rem;
      }
      ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
      li a {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.25rem;
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 6px;
        text-decoration: none;
        color: #111;
        font-weight: 500;
        font-size: 0.95rem;
        transition: border-color 0.15s;
      }
      li a:hover { border-color: #aaa; }
      li a span { font-size: 0.78rem; color: #999; font-weight: 400; }
    </style>
  </head>
  <body>
    <header>
      <h1>Northform QA — Results</h1>
      <p>Client test result dashboards</p>
    </header>
    <main>
      <h2>Client Dashboards</h2>
      <ul>
        {clients.map((c) => (
          <li>
            <a href={`/${c.slug}/`}>
              {c.displayName}
              <span>/{c.slug}/</span>
            </a>
          </li>
        ))}
      </ul>
    </main>
  </body>
</html>
